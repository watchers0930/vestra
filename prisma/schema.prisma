generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// NextAuth 필수 모델
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// 사용자
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?

  // 관리자 계정용
  password       String?

  // 회원 등급
  role           String    @default("PERSONAL") // GUEST | PERSONAL | BUSINESS | REALESTATE | ADMIN
  businessNumber String?                        // 사업자등록번호 (기업/부동산)
  verifyStatus   String    @default("none")     // none | pending | verified | rejected
  dailyLimit     Int       @default(5)          // 일일 분석 횟수

  // NextAuth 관계
  accounts       Account[]
  sessions       Session[]

  // 앱 데이터 관계
  analyses       Analysis[]
  assets         Asset[]

  // 모니터링 & 검증
  monitoredProperties MonitoredProperty[]
  verificationRequests VerificationRequest[]

  // 구독 & 알림
  subscription        Subscription?
  notificationSetting NotificationSetting?

  // 사업성 분석
  feasibilityReports FeasibilityReport[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// 앱 데이터
// ---------------------------------------------------------------------------

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  type      String
  typeLabel String
  address   String
  summary   String   @db.Text
  data      String   @db.Text
  fraudRisk Json?    // 전세사기 위험 평가 결과 (FraudRiskResult)
  vScore    Json?    // V-Score 통합 위험도 결과 (VScoreResult)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id               String   @id @default(cuid())
  userId           String
  address          String
  type             String
  estimatedPrice   Float
  jeonsePrice      Float?
  safetyScore      Int
  riskScore        Int
  lastAnalyzedDate DateTime @default(now())
  priceHistory     String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
}

model RateLimit {
  id        String   @id
  count     Int      @default(1)
  resetTime DateTime
  createdAt DateTime @default(now())

  @@index([resetTime])
}

model DailyUsage {
  id    String @id
  date  String
  count Int    @default(1)

  @@index([date])
}

// ---------------------------------------------------------------------------
// 구독 & 결제
// ---------------------------------------------------------------------------

model Subscription {
  id         String    @id @default(cuid())
  userId     String    @unique
  plan       String    @default("FREE") // FREE | PRO | BUSINESS
  price      Int       @default(0)      // 월 요금 (원)
  status     String    @default("active") // active | canceled | expired
  startDate  DateTime  @default(now())
  endDate    DateTime?
  canceledAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments   Payment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Int
  method         String?      // card | transfer | kakaopay
  status         String       @default("pending") // pending | completed | failed | refunded
  orderId        String?      @unique
  receiptUrl     String?
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  createdAt      DateTime     @default(now())
}

// ---------------------------------------------------------------------------
// 알림 설정
// ---------------------------------------------------------------------------

model NotificationSetting {
  id               String  @id @default(cuid())
  userId           String  @unique
  emailEnabled     Boolean @default(true)
  kakaoEnabled     Boolean @default(false)
  kakaoPhoneNumber String? // 카카오 알림톡 수신 전화번호
  priceAlert       Boolean @default(true)
  analysisReport   Boolean @default(true)
  systemNotice     Boolean @default(true)
  marketingEmail   Boolean @default(false)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 공지사항
// ---------------------------------------------------------------------------

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 감사 로그 (Audit Trail)
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // LOGIN | LOGOUT | LOGIN_FAILED | ADMIN_USER_UPDATE | ADMIN_USER_DELETE | ADMIN_SETTINGS_CHANGE | ANALYSIS_REQUEST | RATE_LIMIT_EXCEEDED | SIGNUP | ROLE_CHANGE
  target    String?  // 대상 리소스 ID (userId, settingKey 등)
  detail    String?  @db.Text // JSON 형태 상세 정보
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 시스템 설정 (관리자 대시보드에서 관리)
// ---------------------------------------------------------------------------

model SystemSetting {
  key       String   @id              // e.g. "AUTH_GOOGLE_ID"
  value     String   @db.Text         // AES-256-GCM 암호화된 값
  category  String   @default("oauth")
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 등기변동 모니터링
// ---------------------------------------------------------------------------

model MonitoredProperty {
  id            String            @id @default(cuid())
  userId        String
  address       String
  lastCheckedAt DateTime?
  lastHash      String?           // 등기부 내용 해시 (변동 감지용)
  status        String            @default("active") // active | paused | expired
  alerts        MonitoringAlert[]
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, address])
  @@index([status])
}

model MonitoringAlert {
  id                  String            @id @default(cuid())
  monitoredPropertyId String
  changeType          String            // mortgage_added | mortgage_removed | seizure_added | ownership_changed | etc.
  summary             String
  detail              String?           @db.Text
  riskLevel           String            @default("medium") // low | medium | high | critical
  isRead              Boolean           @default(false)
  monitoredProperty   MonitoredProperty @relation(fields: [monitoredPropertyId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())

  @@index([monitoredPropertyId])
  @@index([isRead])
}

// ---------------------------------------------------------------------------
// 상호검증 (임대인/임차인)
// ---------------------------------------------------------------------------

model VerificationRequest {
  id              String         @id @default(cuid())
  requesterId     String
  targetEmail     String         // 상대방 이메일
  targetRole      String         // landlord | tenant
  propertyAddress String
  status          String         @default("pending") // pending | accepted | rejected | expired
  message         String?        // 요청 메시지
  sharedReports   SharedReport[]
  expiresAt       DateTime
  requester       User           @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([targetEmail])
  @@index([requesterId])
  @@index([status])
}

model SharedReport {
  id                    String              @id @default(cuid())
  verificationRequestId String
  analysisId            String
  sharedBy              String              // userId of report owner
  consentGiven          Boolean             @default(false)
  consentAt             DateTime?
  verificationRequest   VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)
  createdAt             DateTime            @default(now())

  @@index([verificationRequestId])
}

// ---------------------------------------------------------------------------
// 전세사기 피해사례 데이터
// ---------------------------------------------------------------------------

model FraudCase {
  id          String    @id @default(cuid())
  address     String
  latitude    Float
  longitude   Float
  caseType    String    // jeonse_fraud | deposit_fraud | rental_fraud | other
  amount      Float?    // 피해금액 (원)
  victimCount Int?      // 피해 세대수
  reportDate  DateTime?
  source      String    // government | news | court | user_report
  sourceUrl   String?
  summary     String?   @db.Text
  verified      Boolean   @default(false)
  riskFeatures  Json?     // 사기 사례의 피처 벡터 (전세가율, 근저당비율 등)
  createdAt     DateTime  @default(now())

  @@index([latitude, longitude])
  @@index([caseType])
  @@index([reportDate])
  @@index([verified])
}

// ---------------------------------------------------------------------------
// ML 학습 데이터 (도메인 특화 NLP 모델 학습용)
// ---------------------------------------------------------------------------

model TrainingData {
  id               String   @id @default(cuid())
  rawTextEncrypted String   @db.Text              // AES-256-GCM 암호화된 원문
  rawTextHash      String                         // 중복 검색용 SHA-256 해시
  parsedData       Json?                          // ParsedRegistry JSON
  status           String   @default("pending")   // pending | reviewed | approved | rejected
  reviewNotes      String?  @db.Text
  sourceFileName   String
  sourceType       String                         // pdf | text | image
  confidence       Int      @default(0)           // 등기부등본 감지 신뢰도 0-100
  charCount        Int      @default(0)           // 원문 글자 수
  gapguCount       Int      @default(0)           // 갑구 항목 수
  eulguCount       Int      @default(0)           // 을구 항목 수
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([rawTextHash])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 도메인 용어 사전 (KR-BERT 토크나이저 학습용)
// ---------------------------------------------------------------------------

model DomainVocabulary {
  id         String   @id @default(cuid())
  term       String                          // 용어
  category   String                          // registry_right | legal_action | structure | finance_tax
  source     String   @default("manual")     // manual | auto_extracted
  frequency  Int      @default(1)            // 등장 빈도
  definition String?  @db.Text               // 용어 설명
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([term])
  @@index([category])
}

// ---------------------------------------------------------------------------
// 사업성 분석 보고서 (Feasibility Report)
// ---------------------------------------------------------------------------

model FeasibilityReport {
  id                String   @id @default(cuid())
  userId            String
  projectName       String
  address           String
  purpose           String                  // "아파트" | "오피스텔" | ...
  totalFloorArea    Float                   // 연면적 (㎡)
  totalUnits        Int                     // 세대/호실 수
  mergedContext     Json                    // MergedProjectContext
  verificationData  Json                    // VerificationResult[]
  rationalityData   Json                    // RationalityItem[]
  chapters          Json                    // ChapterOpinion[]
  vScore            Int                     // 0-100
  vScoreGrade       String                  // "A" ~ "F"
  vScoreDetail      Json                    // FeasibilityScore
  status            String   @default("draft") // "draft" | "completed"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  files FeasibilityFile[]

  @@index([userId])
  @@index([address])
}

model FeasibilityFile {
  id         String   @id @default(cuid())
  reportId   String
  filename   String
  fileType   String                        // "pdf" | "docx" | "xlsx" | "hwp"
  fileSize   Int                           // bytes
  pageCount  Int?
  confidence Int?                          // 파싱 신뢰도 0-100
  createdAt  DateTime @default(now())

  report FeasibilityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

// ---------------------------------------------------------------------------
// 적응형 가중치 튜닝 (Adaptive Weight Tuning)
// ---------------------------------------------------------------------------

model WeightConfig {
  id              String   @id @default(cuid())
  weights         Json     // { "등기부 파싱": 0.25, "위험도 스코어": 0.30, ... }
  betaParams      Json     // { "등기부 파싱": { alpha: 12, beta: 4 }, ... }
  brierScore      Float    @default(0)
  logLoss         Float    @default(0)
  ece             Float    @default(0)
  feedbackCount   Int      @default(0)
  improvement     Float    @default(0)
  confidence      Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([isActive])
  @@index([createdAt])
}

model WeightFeedback {
  id             String   @id @default(cuid())
  analysisId     String
  predictedRisk  Float
  actualOutcome  String   // safe | fraud | partial_loss | unknown
  lossAmount     Float?
  featureValues  Json
  weightSnapshot Json
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([actualOutcome])
}

// ---------------------------------------------------------------------------
// 무결성 체인 (Integrity Chain)
// ---------------------------------------------------------------------------

model IntegrityRecord {
  id            String   @id @default(cuid())
  analysisId    String
  analysisType  String   // rights | contract | prediction | jeonse | feasibility
  address       String?
  steps         Int
  stepsData     Json     // AnalysisStep[]
  merkleRoot    String
  isValid       Boolean  @default(true)
  verifiedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([analysisType])
  @@index([isValid])
  @@index([createdAt])
}

model BenchmarkCache {
  id          String   @id @default(cuid())
  key         String   @unique            // "kict:2026-03", "pf_rate:gradeA" 등
  category    String                      // "construction_cost" | "pf_rate" | "cap_rate" | "supply"
  data        Json                        // 벤치마크 수치 데이터
  source      String                      // 데이터 출처
  asOfDate    DateTime                    // 데이터 기준일
  expiresAt   DateTime                    // 캐시 만료일
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// 뉴스·정책 수집기
// ---------------------------------------------------------------------------

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  summary     String   @db.Text
  url         String   @unique
  source      String                        // google | hankyung | mk | molit | moef | nts
  category    String                        // news | policy
  tags        String[]
  policyType  String?                       // 세율변경 | 규제지역 | 대출규제 | 공급정책 | 전세대책
  publishedAt DateTime
  collectedAt DateTime @default(now())
  isAlert     Boolean  @default(false)
  alertAcked  Boolean  @default(false)
  usageLogs   NewsUsageLog[]

  @@index([category, publishedAt(sort: Desc)])
  @@index([isAlert, alertAcked])
}

model NewsUsageLog {
  id        String   @id @default(cuid())
  articleId String
  usedIn    String                          // chat | contract | prediction
  usedAt    DateTime @default(now())

  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([usedIn, usedAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// 보증보험 규칙 관리
// ---------------------------------------------------------------------------

model GuaranteeRule {
  id            String   @id @default(cuid())
  provider      String   // HUG | HF | SGI
  rules         Json     // 기관별 조건 JSON
  version       Int      @default(1)
  isActive      Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  changelog     String?  @db.Text
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, version])
  @@index([provider, isActive])
}
