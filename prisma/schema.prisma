generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// NextAuth 필수 모델
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// 사용자
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?

  // 관리자 계정용
  password       String?

  // 회원 등급
  role           String    @default("PERSONAL") // GUEST | PERSONAL | BUSINESS | REALESTATE | ADMIN
  businessNumber String?                        // 사업자등록번호 (기업/부동산)
  verifyStatus   String    @default("none")     // none | pending | verified | rejected
  dailyLimit     Int       @default(5)          // 일일 분석 횟수

  // NextAuth 관계
  accounts       Account[]
  sessions       Session[]

  // 앱 데이터 관계
  analyses       Analysis[]
  assets         Asset[]

  // 구독 & 알림
  subscription        Subscription?
  notificationSetting NotificationSetting?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// 앱 데이터
// ---------------------------------------------------------------------------

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  type      String
  typeLabel String
  address   String
  summary   String   @db.Text
  data      String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id               String   @id @default(cuid())
  userId           String
  address          String
  type             String
  estimatedPrice   Float
  jeonsePrice      Float?
  safetyScore      Int
  riskScore        Int
  lastAnalyzedDate DateTime @default(now())
  priceHistory     String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
}

model RateLimit {
  id        String   @id
  count     Int      @default(1)
  resetTime DateTime
  createdAt DateTime @default(now())

  @@index([resetTime])
}

model DailyUsage {
  id    String @id
  date  String
  count Int    @default(1)

  @@index([date])
}

// ---------------------------------------------------------------------------
// 구독 & 결제
// ---------------------------------------------------------------------------

model Subscription {
  id         String    @id @default(cuid())
  userId     String    @unique
  plan       String    @default("FREE") // FREE | PRO | BUSINESS
  price      Int       @default(0)      // 월 요금 (원)
  status     String    @default("active") // active | canceled | expired
  startDate  DateTime  @default(now())
  endDate    DateTime?
  canceledAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments   Payment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Int
  method         String?      // card | transfer | kakaopay
  status         String       @default("pending") // pending | completed | failed | refunded
  orderId        String?      @unique
  receiptUrl     String?
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  createdAt      DateTime     @default(now())
}

// ---------------------------------------------------------------------------
// 알림 설정
// ---------------------------------------------------------------------------

model NotificationSetting {
  id             String  @id @default(cuid())
  userId         String  @unique
  emailEnabled   Boolean @default(true)
  kakaoEnabled   Boolean @default(false)
  priceAlert     Boolean @default(true)
  analysisReport Boolean @default(true)
  systemNotice   Boolean @default(true)
  marketingEmail Boolean @default(false)
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 공지사항
// ---------------------------------------------------------------------------

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 시스템 설정 (관리자 대시보드에서 관리)
// ---------------------------------------------------------------------------

model SystemSetting {
  key       String   @id              // e.g. "AUTH_GOOGLE_ID"
  value     String   @db.Text         // AES-256-GCM 암호화된 값
  category  String   @default("oauth")
  updatedAt DateTime @updatedAt
}
